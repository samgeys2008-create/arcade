import socket
import sys

host_ip = input("Voer het IP van de host in: ").strip()

print(f"Probeer te verbinden met {host_ip}:5555...")

try:
    client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    client.settimeout(5)
    client.connect((host_ip, 5555))
    print("Verbonden!")
    
    # Ontvang bericht
    data = client.recv(1024)
    print(f"Ontvangen: {data.decode()}")
    
    # Stuur bericht terug
    client.send(b"Hallo host!")
    print("Bericht teruggestuurd")
    
    client.close()
    
except socket.timeout:
    print("Timeout - Kan geen verbinding maken")
except ConnectionRefusedError:
    print("Verbinding geweigerd - Staat de host wel aan?")
except Exception as e:
    print(f"Fout: {e}")
