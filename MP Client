import pygame
import socket
import threading
import pickle
import time

# Initialize Pygame
pygame.init()

# Constants
WIDTH, HEIGHT = 800, 400
FPS = 60
PADDLE_WIDTH, PADDLE_HEIGHT = 10, 80
BALL_SIZE = 10
PADDLE_SPEED = 5
WHITE = (255, 255, 255)
BLACK = (0, 0, 0)

# Network settings
SERVER_IP = input("Enter server IP address: ")  # e.g., "192.168.1.100"
PORT = 5555

class PongClient:
    def __init__(self):
        # Game objects (will be updated from server)
        self.left_paddle = pygame.Rect(30, HEIGHT//2 - PADDLE_HEIGHT//2, 
                                       PADDLE_WIDTH, PADDLE_HEIGHT)
        self.right_paddle = pygame.Rect(WIDTH - 40, HEIGHT//2 - PADDLE_HEIGHT//2,
                                        PADDLE_WIDTH, PADDLE_HEIGHT)
        self.ball = pygame.Rect(WIDTH//2 - BALL_SIZE//2, HEIGHT//2 - BALL_SIZE//2,
                                BALL_SIZE, BALL_SIZE)
        
        # Scores
        self.left_score = 0
        self.right_score = 0
        
        # Network
        self.socket = None
        self.connected = False
        
        # Setup screen
        self.screen = pygame.display.set_mode((WIDTH, HEIGHT))
        pygame.display.set_caption("Pong Client (Right Paddle)")
        self.clock = pygame.time.Clock()
        
        # Connect to server
        self.connect_to_server()
    
    def connect_to_server(self):
        """Connect to the server"""
        try:
            self.socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self.socket.connect((SERVER_IP, PORT))
            self.connected = True
            print("Connected to server!")
            
            # Start receive thread
            thread = threading.Thread(target=self.receive_data)
            thread.daemon = True
            thread.start()
        except:
            print("Failed to connect to server. Make sure the server is running.")
    
    def receive_data(self):
        """Receive game state from server"""
        while self.connected:
            try:
                data = self.socket.recv(4096)
                if data:
                    game_state = pickle.loads(data)
                    self.ball = game_state['ball']
                    self.left_paddle = game_state['left_paddle']
                    self.right_paddle = game_state['right_paddle']
                    self.left_score = game_state['left_score']
                    self.right_score = game_state['right_score']
            except:
                self.connected = False
                break
    
    def send_data(self):
        """Send paddle position to server"""
        try:
            if self.connected:
                self.socket.send(pickle.dumps(self.right_paddle.y))
        except:
            pass
    
    def move_paddle(self):
        """Move right paddle based on keyboard input"""
        keys = pygame.key.get_pressed()
        if keys[pygame.K_UP] and self.right_paddle.top > 0:
            self.right_paddle.y -= PADDLE_SPEED
        if keys[pygame.K_DOWN] and self.right_paddle.bottom < HEIGHT:
            self.right_paddle.y += PADDLE_SPEED
    
    def draw(self):
        """Draw game objects"""
        self.screen.fill(BLACK)
        
        # Draw paddles
        pygame.draw.rect(self.screen, WHITE, self.left_paddle)
        pygame.draw.rect(self.screen, WHITE, self.right_paddle)
        
        # Draw ball
        pygame.draw.ellipse(self.screen, WHITE, self.ball)
        
        # Draw center line
        pygame.draw.aaline(self.screen, WHITE, (WIDTH//2, 0), (WIDTH//2, HEIGHT))
        
        # Draw scores
        font = pygame.font.Font(None, 36)
        left_text = font.render(str(self.left_score), True, WHITE)
        right_text = font.render(str(self.right_score), True, WHITE)
        self.screen.blit(left_text, (WIDTH//4, 20))
        self.screen.blit(right_text, (3*WIDTH//4, 20))
        
        # Draw connection status
        if not self.connected:
            status_font = pygame.font.Font(None, 24)
            status_text = status_font.render("Disconnected from server", True, (255, 0, 0))
            self.screen.blit(status_text, (WIDTH//2 - 100, HEIGHT - 30))
    
    def run(self):
        """Main game loop"""
        running = True
        while running:
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    running = False
            
            # Game logic
            self.move_paddle()
            self.send_data()
            
            # Draw
            self.draw()
            pygame.display.flip()
            self.clock.tick(FPS)
        
        if self.connected:
            self.socket.close()
        pygame.quit()

if __name__ == "__main__":
    game = PongClient()
    game.run()
